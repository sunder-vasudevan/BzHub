# BizHub Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# --- Admin Credentials ---
# Change these before deploying to any shared/production environment
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# --- Database ---
DB_TYPE=sqlite           # 'sqlite' or 'postgresql'
DB_FILE=inventory.db     # path to SQLite file (only used if DB_TYPE=sqlite)
DB_URL=                  # PostgreSQL connection URL (only used if DB_TYPE=postgresql)

# --- App Mode ---
MODE=desktop             # 'desktop', 'web', or 'api'

# --- Email (optional) ---
SMTP_SERVER=
SMTP_PORT=587
SENDER_EMAIL=
SENDER_PASSWORD=

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*

# --- Debug ---
DEBUG=false
